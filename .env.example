# Example environment configuration file
# Copy this file to .env and customize with your actual values
# IMPORTANT: .env is in .gitignore and contains sensitive information

# ============================================================
# Django Core Configuration
# ============================================================
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECURE_STRING
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
TESTING=False

# ============================================================
# Debug & Development Settings
# ============================================================
# Internal IPs for Django Debug Toolbar (comma-separated)
DJANGO_INTERNAL_IPS=127.0.0.1,0.0.0.0
# Enable SQL query logging to console (True/False)
DJANGO_DEBUG_SQL=False
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DJANGO_LOG_LEVEL=DEBUG

# ============================================================
# Database Configuration
# ============================================================
# Main PostgreSQL connection - single database with two schemas
POSTGRESQL_DB_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/YOUR_DATABASE
# Schema names for backoffice and public databases
BACKOFFICE_DB_SCHEMA=backoffice
BACKEND_DB_SCHEMA=public

# ============================================================
# Security Settings (Production)
# ============================================================
# These settings are only used when DJANGO_DEBUG=False
# Security headers (True/False)
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=True
DJANGO_SECURE_BROWSER_XSS_FILTER=True
# Force HTTPS redirect (True/False) - Set to False in development
DJANGO_SECURE_SSL_REDIRECT=False
# Secure cookies (True/False) - Set to True in production with HTTPS
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

# ============================================================
# Content Security Policy (CSP) - Django 6.0
# ============================================================
# CSP mode: True for report-only (monitoring), False for enforced (production)
# Start with True to identify issues before enforcing
DJANGO_CSP_REPORT_ONLY=False

# ============================================================
# CSRF Configuration
# ============================================================
# Trusted origins for CSRF (comma-separated, no protocol)
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# ============================================================
# Session Configuration
# ============================================================
# Session cookie age in seconds (3600 = 1 hour, 86400 = 24 hours)
DJANGO_SESSION_COOKIE_AGE=3600

# ============================================================
# Pagination Configuration
# ============================================================
# Default page size for list views
DJANGO_DEFAULT_PAGE_SIZE=25

# ============================================================
# Email Configuration
# ============================================================
# Email backend: console (development) or smtp.EmailBackend (production)
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# SMTP server host
DJANGO_EMAIL_HOST=localhost
# SMTP server port
DJANGO_EMAIL_PORT=587
# Use TLS for SMTP (True/False)
DJANGO_EMAIL_USE_TLS=True
# SMTP username (leave empty for console backend)
DJANGO_EMAIL_HOST_USER=
# SMTP password (leave empty for console backend)
DJANGO_EMAIL_HOST_PASSWORD=
# Default from email address
DJANGO_DEFAULT_FROM_EMAIL=noreply@sanfelipe.gob.mx

# ============================================================
# Docker/Deployment Configuration
# ============================================================
# HTTP port to expose (default: 8090)
# HTTP_PORT=8090

# ============================================================
# PostgreSQL Service Configuration (for Docker)
# ============================================================
# These are only used for Docker Compose, NOT for direct Django connections
POSTGRES_DB=backoffice_tramites
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ============================================================
# Tenancy/Multi-Department Configuration
# ============================================================
# These settings allow a single Docker image to serve multiple departments
# Customize for each deployment to set department-specific branding

# Site branding (UI customization)
BACKOFFICE_SITE_TITLE="Ventanilla Urbana Digital"
BACKOFFICE_SITE_HEADER="San Felipe"
BACKOFFICE_SITE_BRAND="Ventanilla Urbana Digital"
BACKOFFICE_SITE_LOGO=

# Site content
BACKOFFICE_WELCOME_SIGN="Ventanilla Urbana Digital - Municipio de San Felipe"
BACKOFFICE_COPYRIGHT="Municipio de San Felipe - Todos los derechos reservados"

# ============================================================
# SFTP Storage Configuration (PDF Files)
# ============================================================
# These settings are used to access PDF files stored on a remote SFTP server
# django-storages[sftp] package must be installed

# SFTP server hostname or IP address
SFTP_HOST=sftp.example.com
# SFTP port number (default: 22)
SFTP_PORT=22
# SFTP username for authentication
SFTP_USERNAME=
# SFTP password for authentication (or use private key)
SFTP_PASSWORD=
# Path to SSH private key file (alternative to password authentication)
# Leave empty if using password authentication
# Supports ~ expansion for home directory (e.g., ~/.ssh/id_rsa)
SFTP_PRIVATE_KEY_PATH=
# Passphrase for SSH private key (only used with SFTP_PRIVATE_KEY_PATH)
# Leave empty if private key has no passphrase
SFTP_PRIVATE_KEY_PASSPHRASE=
# Timeout en segundos para operaciones SFTP
# Default: None (usa el default de paramiko, aprox. 30 segundos)
# SFTP_TIMEOUT=
# SSH host key for server verification (MITM protection)
# REQUIRED in production (DEBUG=False). Optional in development (uses WarningPolicy).
# Format: "ssh-rsa AAAAB3Nza..." or "ssh-ed25519 AAAA..."
# Obtain the host key with: ssh-keyscan -t rsa,ed25519 <host>
# See docs/sftp-host-key.md for details.
# SFTP_HOST_KEY=

# Remote directory paths on SFTP server
# Base directory where tramites PDFs are stored
# Leave empty if not using SFTP storage (will cause warning in sftp command)
SFTP_BASE_DIR=
# Subdirectory for PDF files
SFTP_PDF_DIR=pdfs
