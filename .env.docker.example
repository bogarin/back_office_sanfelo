# ========================================
# Docker Environment Configuration
# ========================================
# Copy this file to .env and fill in the required values
# DO NOT commit .env to version control

# ========================================
# Django Configuration
# ========================================
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key-at-least-50-characters-long
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ========================================
# Server Configuration
# ========================================
# HTTP port to expose (default: 8090)
HTTP_PORT=8090

# ========================================
# PostgreSQL Database Configuration (Backoffice)
# ========================================
POSTGRES_DB=backoffice_tramites
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password-in-production
POSTGRES_PORT=5432

# ========================================
# Keycloak Configuration
# ========================================
# Keycloak Admin Credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-this-keycloak-admin-password

# Keycloak Port (default: 8080)
KEYCLOAK_PORT=8080

# Keycloak Hostname Configuration
KC_HOSTNAME=localhost
KC_HOSTNAME_STRICT=false
KC_HOSTNAME_STRICT_HTTPS=false
KC_HTTP_ENABLED=true

# Keycloak Database Configuration
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change-this-keycloak-db-password

# Keycloak Configuration for Django App
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=backoffice
KEYCLOAK_CLIENT_ID=backoffice-client
KEYCLOAK_CLIENT_SECRET_KEY=generate-this-in-keycloak-admin-console

# ========================================
# Optional: Email Configuration
# ========================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password
# DEFAULT_FROM_EMAIL=noreply@sanfelipe.gob.ar

# ========================================
# Optional: Redis Configuration (for caching)
# ========================================
# REDIS_URL=redis://redis:6379/1
# REDIS_PORT=6379

# ========================================
# Optional: Sentry Configuration (for error tracking)
# ========================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=production

# ========================================
# Optional: AWS Configuration (for S3 storage)
# ========================================
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=https://s3.amazonaws.com
